# Copy this file to backend/.env and replace values for your environment.
# The real .env file is ignored by Git.

# Use "fake" for local deterministic runs or "bedrock" for AWS Bedrock.
REPO_AGENT_LLM_PROVIDER=bedrock

# This is the profile name from ~/.aws/config, not an access key or secret.
REPO_AGENT_AWS_PROFILE=your-sso-profile
REPO_AGENT_AWS_REGION=us-east-1
REPO_AGENT_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# Zero-setup local persistence. The directory is created automatically.
REPO_AGENT_DATABASE_PATH=./data/repo_agent.db
REPO_AGENT_CORS_ALLOW_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
