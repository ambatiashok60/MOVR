{
  "description": "Golden benchmark scenarios for the Playwright generation engine. Every prompt, decision-logic, or policy change must be run against these before merging so accuracy, reuse, repair, validation, and latency regressions are caught by numbers.",
  "scenarios": [
    {
      "name": "append-employee-empty-state",
      "kind": "append",
      "test_case_name": "Employee empty state",
      "steps": [
        "Login as HR admin",
        "Open the employees list",
        "Filter to a state with no employees",
        "Verify the empty state banner is shown"
      ],
      "expected": {
        "action": "append_new_test",
        "target_spec": "e2e/employee.spec.ts",
        "reuse_signals": ["EmployeePage"],
        "validation_should_pass": true
      }
    },
    {
      "name": "extend-employee-update-flow",
      "kind": "extend",
      "test_case_name": "Update employee after creation",
      "steps": [
        "Create an employee",
        "Update the employee's department",
        "Verify the updated department is shown"
      ],
      "expected": {
        "action": "extend_existing_test",
        "target_spec": "e2e/employee.spec.ts",
        "reuse_signals": ["creates an employee"],
        "validation_should_pass": true
      }
    },
    {
      "name": "create-payroll-export-spec",
      "kind": "create_spec",
      "test_case_name": "Payroll export",
      "steps": [
        "Open payroll reports",
        "Export the quarterly report",
        "Verify the download completes"
      ],
      "expected": {
        "action": "create_new_spec",
        "target_spec": "e2e/payroll-export.spec.ts",
        "validation_should_pass": true
      }
    },
    {
      "name": "repair-broken-generated-patch",
      "kind": "patch_repair",
      "test_case_name": "Repairable generation",
      "steps": ["Open dashboard", "Verify widgets render"],
      "expected": {
        "validation_should_pass": true
      }
    }
  ]
}
