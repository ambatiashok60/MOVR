{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "ai-workspace-preview": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/ai-workspace-preview",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "public" }],
            "styles": ["node_modules/primeicons/primeicons.css", "src/styles.scss"]
          },
          "configurations": {
            "production": { "outputHashing": "all", "budgets": [{ "type": "initial", "maximumWarning": "1mb", "maximumError": "2mb" }] },
            "development": { "optimization": false, "sourceMap": true, "extractLicenses": false }
          },
          "defaultConfiguration": "development"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "development": { "buildTarget": "ai-workspace-preview:build:development" },
            "production": { "buildTarget": "ai-workspace-preview:build:production" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
