AWS_AUTH_MODE=sso
AWS_PROFILE=your-sso-profile
AWS_SSO_AUTO_LOGIN=true
AWS_SSO_LOGIN_TIMEOUT_SECONDS=180
LOG_LEVEL=INFO
# Optional absolute override. Default: <project>/backend/logs
# BACKEND_LOG_DIR=/absolute/path/to/backend/logs
AWS_REGION=us-east-1
# Used only when AWS_AUTH_MODE=keys; never expose these to Angular.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_MAX_TOKENS=8192
BEDROCK_CONNECT_TIMEOUT_SECONDS=10
BEDROCK_READ_TIMEOUT_SECONDS=120
# Comma-separated absolute paths. This .env file belongs at the project root.
WORKSPACE_ALLOWED_ROOTS=/Users/you/Documents,/Users/you/Projects
WORKSPACE_MAX_FILES=10000
WORKSPACE_MAX_FILE_BYTES=1048576
AGENT_MAX_STEPS=12
AGENT_MAX_RESPONSE_CONTINUATIONS=3
AGENT_STATE_DIR=.agent-state
CUSTOM_TOOL_TIMEOUT_SECONDS=5
FRONTEND_ORIGIN=http://localhost:4200
# Optional protection for non-loopback deployments. Send Authorization: Bearer <token>.
# Leave empty for local-only development.
API_AUTH_TOKEN=
MAX_REQUEST_BYTES=2000000
REQUEST_TIMEOUT_SECONDS=900
